{
  "name": "momotodo-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "check:package-manager": "node apps/desktop/scripts/check-package-manager.mjs",
    "tauri": "yarn --cwd apps/desktop tauri",
    "tauri:dev": "yarn --cwd apps/desktop tauri:dev",
    "tauri:build": "yarn --cwd apps/desktop tauri:build",
    "predocs:dev": "yarn check:package-manager",
    "docs:dev": "vitepress dev docs",
    "predocs:build": "yarn check:package-manager",
    "docs:build": "vitepress build docs",
    "predocs:preview": "yarn check:package-manager",
    "docs:preview": "vitepress preview docs",
    "verify": "yarn verify:desktop:test && yarn verify:desktop:build && yarn verify:tauri && yarn verify:schema && yarn verify:contracts",
    "verify:desktop:test": "yarn --cwd apps/desktop test",
    "verify:desktop:build": "yarn --cwd apps/desktop build",
    "verify:tauri": "cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "verify:schema": "node node_modules/typescript/bin/tsc -p packages/schema/tsconfig.json",
    "verify:contracts": "node node_modules/typescript/bin/tsc -p packages/contracts/tsconfig.json"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "packageManager": "yarn@4.14.1"
}
